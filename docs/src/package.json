        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "author": "",
    "license": "ISC",
    "dependencies": {
        "cross-env": "^10.0.0",
        "mdx-to-md": "^0.5.0",
        "react": "^19.1.0",
